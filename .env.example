ANTHROPIC_API_KEY=

# Only needed for `scrutineer review --pr <number>`
GITHUB_TOKEN=

# Optional: override the default model per provider (claude-sonnet-5 / auto-detected from
# your local Ollama instance, falling back to phi4 if nothing is running or pulled)
# SCRUTINEER_MODEL_ANTHROPIC=
# SCRUTINEER_MODEL_OLLAMA=

# Optional: point --provider ollama at a non-default Ollama host (defaults to
# http://127.0.0.1:11434). scrutineer warns on stderr if this isn't a loopback address,
# since review content (diffs, AST context) is sent to whatever host this points at.
# OLLAMA_HOST=
